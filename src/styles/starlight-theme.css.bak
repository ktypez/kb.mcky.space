/*
 * Blueprint Technical — Starlight Theme
 * Generated from design tokens: blueprint-technical
 * Font: Space Grotesk | Corners: sharp (0 radius)
 */

/* ── Google Font ──────────────────────────────────── */
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

/* ── Base ─────────────────────────────────────────── */
:root {
  /* Font */
  --sl-font: 'Space Grotesk', system-ui, sans-serif;
  --sl-font-mono: 'Space Grotesk', ui-monospace, monospace;

  /* Font sizes */
  --sl-font-size-xs: 0.714rem;   /* 10px */
  --sl-font-size-sm: 0.857rem;   /* 12px */
  --sl-font-size-base: 1rem;     /* 14px → 1rem base */
  --sl-font-size-lg: 1.286rem;   /* 18px */
  --sl-font-size-xl: 1.429rem;   /* 20px */
  --sl-font-size-2xl: 1.714rem;  /* 24px */
  --sl-font-size-3xl: 2.143rem;  /* 30px */
  --sl-font-size-4xl: 2.571rem;  /* 36px */

  /* Spacing */
  --sl-spacing-1: 0.25rem;   /* 4px */
  --sl-spacing-2: 0.5rem;    /* 8px */
  --sl-spacing-3: 0.75rem;   /* 12px */
  --sl-spacing-4: 1rem;      /* 16px */
  --sl-spacing-5: 1.25rem;   /* 20px */
  --sl-spacing-6: 1.5rem;    /* 24px */
  --sl-spacing-8: 2rem;      /* 32px */
  --sl-spacing-10: 2.5rem;   /* 40px */
  --sl-spacing-12: 3rem;     /* 48px */
  --sl-spacing-16: 4rem;     /* 64px */

  /* Border radius — sharp edges */
  --sl-border-radius: 0px;
  --sl-border-radius-sm: 0px;
  --sl-border-radius-lg: 0px;

  /* Shadows — subtle, technical */
  --sl-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --sl-shadow-card: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
  --sl-shadow-none: none;

  /* ─── Light mode ─────────────────────────────── */
  --sl-color-bg: #F4F4F4;
  --sl-color-bg-muted: rgba(26, 26, 26, 0.03);
  --sl-color-bg-nav: rgba(255, 255, 255, 0.6);
  --sl-color-bg-sidebar: rgba(255, 255, 255, 0.4);
  --sl-color-text: #1A1A1A;
  --sl-color-text-secondary: #4A4A4A;
  --sl-color-text-muted: #A1A1A1;
  --sl-color-text-placeholder: rgba(26, 26, 26, 0.3);
  --sl-color-text-balance: #1A1A1A;
  --sl-color-accent: #1A1A1A;
  --sl-color-accent-high: #000000;
  --sl-color-accent-low: #C0C0C0;

  /* Accent high / low (Starlight 0.28+) */
  --sl-color-accent-high: #000000;
  --sl-color-accent-low: #C0C0C0;

  /* Links */
  --sl-color-link: #5A7C9A;
  --sl-color-link-hover: #4A6B85;
  --sl-color-link-active: #4A6B85;

  /* Borders */
  --sl-color-border: rgba(26, 26, 26, 0.1);
  --sl-color-border-subtle: rgba(26, 26, 26, 0.05);
  --sl-color-border-hover: rgba(26, 26, 26, 0.2);

  /* Semantic: Info */
  --sl-color-info: #5A7C9A;
  --sl-color-info-bg: rgba(90, 124, 154, 0.1);
  --sl-color-info-text: #5A7C9A;

  /* Semantic: Tip/Success */
  --sl-color-success: #4A7C59;
  --sl-color-success-bg: rgba(74, 124, 89, 0.1);
  --sl-color-success-text: #4A7C59;

  /* Semantic: Caution/Warning */
  --sl-color-warning: #9A8A4A;
  --sl-color-warning-bg: rgba(154, 138, 74, 0.1);
  --sl-color-warning-text: #9A8A4A;

  /* Semantic: Danger */
  --sl-color-danger: #8B4A4A;
  --sl-color-danger-bg: rgba(139, 74, 74, 0.1);
  --sl-color-danger-text: #8B4A4A;

  /* Grid pattern */
  --sl-color-grid: rgba(224, 224, 224, 0.8);
  --sl-grid-size: 20px;

  /* Code blocks */
  --sl-color-code-bg: rgba(26, 26, 26, 0.03);
  --sl-color-code-inline-bg: rgba(26, 26, 26, 0.06);

  /* Header */
  --sl-color-bg-header: rgba(255, 255, 255, 0.6);

  /* Footer */
  --sl-color-bg-footer: rgba(26, 26, 26, 0.03);

  /* Scrollbar */
  --sl-color-scrollbar: #1A1A1A;
  --sl-color-scrollbar-hover: #000000;
}

/* ── Dark mode ────────────────────────────────────── */
.sl-theme-dark {
  --sl-color-bg: #0F0F0F;
  --sl-color-bg-muted: rgba(240, 240, 240, 0.03);
  --sl-color-bg-nav: rgba(55, 55, 55, 0.7);
  --sl-color-bg-sidebar: rgba(40, 40, 40, 0.5);
  --sl-color-text: #F0F0F0;
  --sl-color-text-secondary: #C0C0C0;
  --sl-color-text-muted: #909090;
  --sl-color-text-placeholder: rgba(240, 240, 240, 0.35);
  --sl-color-text-balance: #F0F0F0;
  --sl-color-accent: #E5E5E5;
  --sl-color-accent-high: #FFFFFF;
  --sl-color-accent-low: #6A6A6A;

  --sl-color-accent-high: #FFFFFF;
  --sl-color-accent-low: #6A6A6A;

  /* Links */
  --sl-color-link: #7A9BBA;
  --sl-color-link-hover: #8AABCA;
  --sl-color-link-active: #8AABCA;

  /* Borders */
  --sl-color-border: rgba(240, 240, 240, 0.1);
  --sl-color-border-subtle: rgba(240, 240, 240, 0.05);
  --sl-color-border-hover: rgba(240, 240, 240, 0.2);

  /* Semantic: Info */
  --sl-color-info: #7A9BBA;
  --sl-color-info-bg: rgba(122, 155, 186, 0.15);
  --sl-color-info-text: #7A9BBA;

  /* Semantic: Tip/Success */
  --sl-color-success: #6B9B7A;
  --sl-color-success-bg: rgba(107, 155, 122, 0.15);
  --sl-color-success-text: #6B9B7A;

  /* Semantic: Caution/Warning */
  --sl-color-warning: #C4B66A;
  --sl-color-warning-bg: rgba(196, 182, 106, 0.15);
  --sl-color-warning-text: #C4B66A;

  /* Semantic: Danger */
  --sl-color-danger: #AB6A6A;
  --sl-color-danger-bg: rgba(171, 106, 106, 0.15);
  --sl-color-danger-text: #AB6A6A;

  /* Grid */
  --sl-color-grid: rgba(58, 58, 58, 0.5);

  /* Code blocks */
  --sl-color-code-bg: rgba(240, 240, 240, 0.03);
  --sl-color-code-inline-bg: rgba(240, 240, 240, 0.06);

  /* Header */
  --sl-color-bg-header: rgba(55, 55, 55, 0.7);

  /* Footer */
  --sl-color-bg-footer: rgba(240, 240, 240, 0.03);

  /* Scrollbar */
  --sl-color-scrollbar: #707070;
  --sl-color-scrollbar-hover: #909090;

  /* Shadows for dark mode */
  --sl-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
  --sl-shadow-card: 0 1px 3px 0 rgb(0 0 0 / 0.3), 0 1px 2px -1px rgb(0 0 0 / 0.3);
}

/* ── Blueprint grid background ────────────────────── */
.astro-docs,
.page,
main {
  background-image:
    linear-gradient(var(--sl-color-grid) 1px, transparent 1px),
    linear-gradient(90deg, var(--sl-color-grid) 1px, transparent 1px);
  background-size: var(--sl-grid-size) var(--sl-grid-size);
}

/* ── Override Starlight component styles ──────────── */

/* Remove all border-radius globally — blueprint look */
*,
*::before,
*::after {
  border-radius: 0 !important;
}

/* Sidebar */
.site-title,
.nav-list a,
.nav-list a.active {
  font-family: var(--sl-font);
  letter-spacing: 0.02em;
  text-transform: uppercase;
  font-size: var(--sl-font-size-sm);
  font-weight: 500;
}

/* Headings — technical, uppercase feel */
h1, h2, h3, h4, h5, h6 {
  font-family: var(--sl-font);
  font-weight: 600;
  letter-spacing: -0.01em;
}

h1 {
  font-size: var(--sl-font-size-4xl);
}

h2 {
  font-size: var(--sl-font-size-2xl);
}

h3 {
  font-size: var(--sl-font-size-xl);
}

/* Code blocks — clean, technical */
pre,
code,
.sl-markdown-content code {
  font-family: var(--sl-font-mono);
}

/* Buttons — sharp corners, subtle shadows */
.sl-button {
  font-family: var(--sl-font);
  font-weight: 500;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  font-size: var(--sl-font-size-sm);
  box-shadow: var(--sl-shadow-sm);
  transition: box-shadow 150ms ease-out, background 150ms ease-out;
}

/* Table styling — blueprint grid tables */
table {
  font-family: var(--sl-font);
  font-size: var(--sl-font-size-sm);
}

th {
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-size: var(--sl-font-size-xs);
}

/* Callout / Admonition boxes */
.sl-markdown-content .note,
.sl-markdown-content .tip,
.sl-markdown-content .caution,
.sl-markdown-content .danger {
  font-family: var(--sl-font);
}

/* Badges */
.badge {
  font-family: var(--sl-font);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: var(--sl-font-size-xs);
  font-weight: 600;
}

/* Card styling */
.card {
  font-family: var(--sl-font);
  box-shadow: var(--sl-shadow-card);
  transition: box-shadow 150ms ease-out;
}

.card:hover {
  box-shadow: 0 2px 8px rgb(0 0 0 / 0.12);
}
